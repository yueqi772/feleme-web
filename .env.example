# ============================================
# 微信登录配置
# 微信开放平台：https://open.weixin.qq.com
# ============================================

# 微信开放平台创建的网站应用的 AppID
VITE_WECHAT_APP_ID=your_appid_here

# 授权回调地址（与微信开放平台后台配置的域名一致）
# 开发环境示例：
VITE_WECHAT_REDIRECT_URI=http://localhost:5173/wechat-callback
# 生产环境示例：
# VITE_WECHAT_REDIRECT_URI=https://yourdomain.com/wechat-callback

# ============================================
# 后端服务地址（微信登录 token 交换）
# ============================================
# 开发环境：后端服务运行在 localhost:3001
VITE_AUTH_SERVER_URL=http://localhost:3001
# 生产环境：替换为你的后端域名
# VITE_AUTH_SERVER_URL=https://api.yourdomain.com
